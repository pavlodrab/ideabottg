# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Telegram user id of the primary owner (get from @userinfobot)
OWNER_ID=0

# Postgres connection string (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Default timezone for schedules
TZ=Europe/Kyiv

# Optional: persistent FSM storage. Set this to enable multi-step admin
# flows (custom prompt text, custom cron, custom quiet-hours window) to
# survive bot restarts. Without it, the bot uses in-memory storage and
# loses state on every redeploy — meaning if Railway redeploys between
# the moment a user clicks a button and types their reply, the reply
# is silently dropped. On Railway, add the Redis plugin and this var
# is injected automatically.
# REDIS_URL=redis://default:password@host:port/0

# Optional: log level
LOG_LEVEL=INFO

# Night mode: bot will not send scheduled/proactive messages during this
# window. Times are HH:MM in the TZ above. Window may wrap midnight.
# Replies to direct user commands are not affected.
QUIET_HOURS_ENABLED=true
QUIET_HOURS_START=23:00
QUIET_HOURS_END=08:00
